# Copie para .env ao correr Simcag.PriceAnalysisService.Api (DotNetEnv).

# PostgreSQL (padrão)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=simcag_pricing;Username=postgres;Password=postgres
# Aliases legados (vão ser removidos): DB__*

# HTTP → Market Data Service (default no código: http://localhost:8082)
# MARKET_DATA_API_URL=http://localhost:8082
# MARKETDATA_SERVICE_URL=http://localhost:8082
# MarketData__BaseUrl=http://localhost:8082

# Redis (opcional) — cache de referência de mercado; se omitido, usa NullMarketDataCache
# REDIS__CONNECTION=localhost:6379,abortConnect=false

# RabbitMQ
RABBITMQ__HOST=localhost
RABBITMQ__PORT=5672
RABBITMQ__USERNAME=guest
RABBITMQ__PASSWORD=guest
RABBITMQ__VIRTUALHOST=/
# RABBITMQ__EVENTS_EXCHANGE=events
